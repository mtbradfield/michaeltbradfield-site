---
layout: layouts/base.njk
title: Essays
description: Essays exploring public life, meaning, responsibility, and the shape of things we share
---

<div class="endorsement-page shelf-page">

  <p class="essay-back"><a href="/writing/">← Back to The Library</a></p>

  <div class="endorsement-layout shelf-layout">

    <aside class="endorsement-nav shelf-nav">
      <h1>Essays</h1>

      <p class="endorsement-subtitle shelf-subtitle">
        Essays that press more directly into argument, interpretation, and the public meanings of life together.
      </p>

      <div class="shelf-nav-group browse-nav-group">
        <a class="browse-nav-link" href="/reflections/">Reflections</a>
      </div>

      <div class="shelf-nav-group browse-nav-group">
        <a class="browse-nav-link" href="/essays/">Essays</a>
      </div>

      <div class="shelf-nav-group browse-nav-group">
        <a class="browse-nav-link" href="/working-papers/">Working Papers</a>
      </div>

      <div class="shelf-nav-group browse-nav-group">
        <a class="browse-nav-link" href="/notes/">Notes</a>
      </div>
    </aside>

    <main class="endorsement-main shelf-main">

      <section class="panel browse-panel">
        <div class="browse-intro">
          <h2>About This Shelf</h2>
          <p>
            This shelf gathers essays that engage public life, moral judgment, institutional meaning,
            and the questions that arise when personal conviction meets our common world.
          </p>
        </div>

        <div class="browse-list browse-list--series">

          {% set renderedSeries = [] %}

          {% for item in collections.essays | sort(attribute="data.title") %}

            {% if item.data.series_slug %}

              {% if item.data.series_slug not in renderedSeries and item.data.series_order == 1 %}

                <article class="browse-series">
                  <h3 class="browse-series-title">
                    <a href="/series/{{ item.data.series_slug }}/">
                      {{ item.data.series_title }} Series
                    </a>
                  </h3>

                  {% for seriesItem in collections.essays | sort(attribute="data.series_order") %}
                    {% if seriesItem.data.series_slug == item.data.series_slug %}
                      <div class="browse-series-item">
                        <a href="{{ seriesItem.url }}">
                          Part {{ seriesItem.data.series_order }}: {{ seriesItem.data.title }}
                        </a>
                      </div>
                    {% endif %}
                  {% endfor %}
                </article>

                {% set renderedSeries = renderedSeries %}
              {% endif %}

            {% else %}

              <article class="browse-item">
                <a class="browse-item-link" href="{{ item.url }}">
                  <h3 class="browse-item-title">{{ item.data.title }}</h3>

                  {% if item.data.subtitle %}
                    <p class="browse-item-subtitle">{{ item.data.subtitle }}</p>
                  {% endif %}

                  {% if item.data.description %}
                    <p class="browse-item-blurb">{{ item.data.description }}</p>
                  {% endif %}
                </a>
              </article>

            {% endif %}

          {% endfor %}

        </div>
      </section>

    </main>

  </div>
</div>