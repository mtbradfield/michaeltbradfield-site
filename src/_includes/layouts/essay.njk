<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ title }} · Michael T. Bradfield</title>
  <meta name="description" content="{{ description or '' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Source+Serif+4:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css" />
</head>
<body class="body--essay">
  <header class="site-header">
    <div class="container header-inner">
      <a class="site-title" href="/">Michael T. Bradfield</a>

      <nav class="site-nav">

  <div class="site-nav-item site-nav-item--dropdown">
    <button class="site-nav-toggle" type="button" aria-expanded="false">
      Writing
    </button>
    <div class="site-nav-menu">
      <ul class="link-list">
        <li><a href="/writing/">The Library</a></li>
        <li><a href="#">Essays</a></li>
        <li><a href="#">Reflections</a></li>
        <li><a href="#">Notes</a></li>
        <li><a href="#">Working Papers</a></li>
      </ul>
    </div>
  </div>

  <div class="site-nav-item site-nav-item--dropdown">
    <button class="site-nav-toggle" type="button" aria-expanded="false">
      Projects
    </button>
    <div class="site-nav-menu">
      <ul class="link-list">
        <li><a href="/endorsement/">Endorsement</a></li>
        <li><a href="/pluralism/">Pluralism</a></li>
        <li><a href="#">Covenantal Economics</a></li>
        <li><a href="#">Voter Identification</a></li>
      </ul>
    </div>
  </div>

  <a href="/writing/">Library</a>
  <a href="/about/">About</a>
</nav>
    </div>
  </header>

  <main class="container page-surface page-surface--essay">
    <article class="essay-page">
      <p class="essay-back">
  <a href="{{ back_link or '/writing/' }}">← Back to {{ back_label or 'The Library' }}</a>
  </p>

      <header class="essay-header">
        <h1>{{ title }}</h1>

        {% if subtitle %}
          <p class="essay-subtitle">{{ subtitle }}</p>
        {% endif %}

        {#
          {% if revised %}
          <p class="essay-meta">Revised {{ revised }}</p>
        {% endif %}
        #}
      </header>

      {% if epigraph %}
        <blockquote class="essay-epigraph">
          <p>{{ epigraph.text }}</p>
          {% if epigraph.source %}
            <footer>— {{ epigraph.source }}</footer>
          {% endif %}
        </blockquote>
      {% endif %}

      <div class="essay-body">
        {{ content | safe }}
      </div>

      <div class="essay-cadence">* * *</div>

      <footer class="essay-footer">
        <p><strong>Michael T. Bradfield</strong><br>Winchester, Virginia</p>

        {% if first_written or revised %}
          <p class="essay-note">
            {% if first_written %}First written: {{ first_written }}{% endif %}
            {% if first_written and revised %}<br>{% endif %}
            {% if revised %}Revised: {{ revised }}{% endif %}
          </p>
        {% endif %}

        <p class="essay-note">Essays may be shared with attribution.</p>
      </footer>

      {% if further_reading %}
        <section class="essay-related">
          <h2>Further Reading in This Library</h2>
          <ul class="link-list">
            {% for item in further_reading %}
              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}
    </article>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>© 2026 Michael T. Bradfield</span>
      <span><a href="/contact/">Contact</a></span>
    </div>
  </footer>
  <script>
  document.addEventListener("DOMContentLoaded", function () {
    const toggles = document.querySelectorAll(".site-nav-toggle");

    toggles.forEach((toggle) => {
      const menu = toggle.nextElementSibling;

      toggle.addEventListener("click", function (event) {
        event.stopPropagation();
        const isOpen = this.getAttribute("aria-expanded") === "true";

        toggles.forEach((otherToggle) => {
          otherToggle.setAttribute("aria-expanded", "false");
          otherToggle.nextElementSibling.classList.remove("is-open");
        });

        if (!isOpen) {
          this.setAttribute("aria-expanded", "true");
          menu.classList.add("is-open");
        }
      });
    });

    document.addEventListener("click", function () {
      toggles.forEach((toggle) => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.nextElementSibling.classList.remove("is-open");
      });
    });
  });
</script>
</body>
</html>