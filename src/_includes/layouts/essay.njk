<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ title }} · Michael T. Bradfield</title>
  <meta name="description" content="{{ description or '' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Source+Serif+4:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css" />
</head>

<body class="body--essay">

{% include "partials/site-header.njk" %}

   <main class="container page-surface page-surface--essay">
    <article class="essay-page">

      <div class="essay-top-controls">
        <p class="essay-back">
          <a href="{{ back_link or '/' }}"
             onclick="if (document.referrer && document.referrer.includes(window.location.origin)) { event.preventDefault(); window.history.back(); return false; }">
            ← Back
          </a>
        </p>

        <button id="contrast-toggle" class="contrast-toggle" type="button">
          Reading Contrast
        </button>
      </div>

      <header class="piece-header">
        <h1 class="piece-title">{{ title }}</h1>

        {% if subtitle %}
          <p class="piece-subtitle">{{ subtitle }}</p>
        {% endif %}

        {% if epigraph %}
          <div class="piece-epigraph">
            <p>{{ epigraph }}</p>

            {% if epigraph_attribution %}
              <p class="piece-epigraph-source">— {{ epigraph_attribution }}</p>
            {% endif %}
          </div>
        {% endif %}
      </header>

{% if series_title and series_slug %}
  <p class="piece-series-note">
    {% if series_order and series_order > 1 %}
      <a href="/series/{{ series_slug }}/">
        Part {{ series_order }} of the {{ series_title }} Series
      </a>
    {% elif series_order %}
      Part {{ series_order }} of the {{ series_title }} Series
    {% else %}
      <a href="/series/{{ series_slug }}/">
        Part of the {{ series_title }} Series
      </a>
    {% endif %}
  </p>
{% elif series_title %}
  <p class="piece-series-note">
    {% if series_order %}
      Part {{ series_order }} of the {{ series_title }} Series
    {% else %}
      Part of the {{ series_title }} Series
    {% endif %}
  </p>
{% endif %}

      <div class="piece-body">
        {{ content | safe }}

      </div>

      <footer class="essay-footer">
        <p><strong>Michael T. Bradfield</strong><br>Winchester, Virginia</p>
      
        {% if first_written or revised %}
          <p class="essay-note">
            {% if first_written %}First written: {{ first_written }}{% endif %}
            {% if first_written and revised %}<br>{% endif %}
            {% if revised %}Revised: {{ revised }}{% endif %}
          </p>
        {% endif %}

        <p class="essay-note">Essays may be shared with attribution.</p>
      </footer>

      {% if document_file %}
        <div class="document-links">
          <hr class="document-links-separator">
          <p><a href="{{ document_file }}" target="_blank" rel="noopener">View in browser</a></p>
          <p><a href="{{ document_file }}" download>Download</a></p>
        </div>
      {% endif %}

      {% if series_type == "sequential" and series_slug and series_order %}

  {% set currentOrder = series_order %}

  {% set prevItem = null %}
  {% set nextItem = null %}

  {% for item in collections.all %}
    {% if item.data.series_slug == series_slug and item.data.series_type == "sequential" %}
      {% if item.data.series_order == currentOrder - 1 %}
        {% set prevItem = item %}
      {% endif %}
      {% if item.data.series_order == currentOrder + 1 %}
        {% set nextItem = item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  <nav class="series-nav">
    {% if prevItem %}
      <a class="series-prev" href="{{ prevItem.url }}">← Part {{ prevItem.data.series_order }}</a>
    {% endif %}

    {% if nextItem %}
      <a class="series-next" href="{{ nextItem.url }}">Part {{ nextItem.data.series_order }} →</a>
    {% endif %}
  </nav>

{% endif %}

      {% if related_reading and related_reading.length %}
        <section class="essay-related">
          <h2>Related Reading</h2>
          <ul class="link-list">
            {% for item in related_reading %}
              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}

    </article>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>© 2026 Michael T. Bradfield</span>
      <span><a href="/contact/">Contact</a></span>
    </div>
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const toggle = document.getElementById("contrast-toggle");

      if (!toggle) return;

      // Load saved setting
      if (localStorage.getItem("contrastMode") === "true") {
        document.documentElement.classList.add("high-contrast");
      }

      toggle.addEventListener("click", () => {
        document.documentElement.classList.toggle("high-contrast");

        localStorage.setItem(
          "contrastMode",
          document.documentElement.classList.contains("high-contrast")
        );
      });
    });
  </script>

  <script>
  const btn = document.getElementById("contrast-toggle");

  if (btn) {
    function setContrastState(enabled) {
      if (enabled) {
        document.body.classList.add("high-contrast");
        btn.textContent = "Standard View";
        localStorage.setItem("contrast", "on");
      } else {
        document.body.classList.remove("high-contrast");
        btn.textContent = "Reading Contrast";
        localStorage.setItem("contrast", "off");
      }
    }

    // Load saved preference
    const saved = localStorage.getItem("contrast");
    setContrastState(saved === "on");

    // Toggle on click
    btn.addEventListener("click", function () {
      const isOn = document.body.classList.contains("high-contrast");
      setContrastState(!isOn);
    });
  }
</script>

</body>
</html>
