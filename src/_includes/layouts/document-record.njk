<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ title }} · Michael T. Bradfield</title>
  <meta name="description" content="{{ description or '' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Source+Serif+4:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="site-title" href="/">Michael T. Bradfield</a>

      <nav class="site-nav">

        <div class="site-nav-item site-nav-item--dropdown">
          <button class="site-nav-toggle" type="button" aria-expanded="false">
            Writing
          </button>
          <div class="site-nav-menu">
            <ul class="link-list">
              <li><a href="/writing/">The Library</a></li>
              <li><a href="/essays/">Essays</a></li>
              <li><a href="/reflections/">Reflections</a></li>
              <li><a href="/working-papers/">Working Papers</a></li>
              <li><a href="/notes/">Notes</a></li>
            </ul>
          </div>
        </div>

        <div class="site-nav-item site-nav-item--dropdown">
          <button class="site-nav-toggle" type="button" aria-expanded="false">
            Projects
          </button>
          <div class="site-nav-menu">
            <ul class="link-list">
              <li><a href="/endorsement/">Endorsement</a></li>
              <li><a href="/pluralism/">Pluralism</a></li>
              <li><a href="/covenantal-economics/">Covenantal Economics</a></li>
              <!-- <li><a href="/voter-identification/">Voter Identification</a></li> -->
              <li><a href="/transforming-community/">Transforming Community</a></li>
            </ul>
          </div>
        </div>

        <a href="/writing/">Library</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>

      </nav>
    </div>
  </header>

  <main class="container page-surface page-surface--essay">
    <article class="essay-page">

      <p class="essay-back">
        <a href="{{ back_link or '/' }}"
           onclick="if (document.referrer && document.referrer.includes(window.location.origin)) { event.preventDefault(); window.history.back(); return false; }">
         ← Back
        </a>
      </p>

      <header class="piece-header">
        <h1 class="piece-title">{{ title }}</h1>

        {% if subtitle %}
          <p class="piece-subtitle">{{ subtitle }}</p>
        {% endif %}

        {% if description %}
          <p class="document-description">{{ description }}</p>
        {% endif %}
      </header>

      {% if series_title %}
        <p class="piece-series-note">
          {% if series_order %}
            Part {{ series_order }} of the {{ series_title }}
          {% else %}
            Part of the {{ series_title }}
          {% endif %}
        </p>
      {% endif %}

      <div class="piece-body">
        {{ content | safe }}

        {% if document_file %}
          <div class="document-links">
            <hr class="document-links-separator">
            <p><a href="{{ document_file }}" target="_blank" rel="noopener">Open in browser</a></p>
            <p><a href="{{ document_file }}" download>Download</a></p>
          </div>
        {% endif %}

        {% if originally_published %}
          <p class="essay-note">
            Originally published on {{ originally_published.platform }}{% if originally_published.date %}, {{ originally_published.date }}{% endif %}.
          </p>
        {% endif %}
      </div>

      {% if related_reading and related_reading.length %}
        <section class="essay-related">
          <h2>Related Reading</h2>
          <ul class="link-list">
            {% for item in related_reading %}
              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}

    </article>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>© 2026 Michael T. Bradfield</span>
      <span><a href="/contact/">Contact</a></span>
    </div>
  </footer>
</body>
</html>